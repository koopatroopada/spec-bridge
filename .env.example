# spec-bridge 环境变量
#
# DEEPSEEK_API_KEY: 用于内置 promptfoo 测试功能（chat 模型）
# 在 app 内直接运行 eval 时需要
# DEEPSEEK_API_KEY=sk-...

# SILICONFLOW_API_KEY: 用于 promptfoo similar 断言的 embedding 计算
# 走硅基流动的 OpenAI 兼容接口（默认模型 BAAI/bge-large-zh-v1.5）
# SILICONFLOW_API_KEY=sk-...

# Vercel 部署时，构建产物的 base URL（如自定义域名）
# NEXT_PUBLIC_SITE_URL=https://spec-bridge.example.com
